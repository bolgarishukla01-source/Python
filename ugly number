def is_ugly(n: int) -> bool:
    # Ugly numbers must be positive integers
    if n <= 0:
        return False
        
    # Repeatedly divide by the allowed prime factors
    for factor in [2, 3, 5]:
        while n % factor == 0:
            n //= factor
            
    # If reduced to 1, it's an ugly number
    return n == 1

# Test cases
print(is_ugly(6))   # True (6 = 2 * 3)
print(is_ugly(14))  # False (14 = 2 * 7, 7 is not allowed)
print(is_ugly(1))   # True (1 has no other prime factors)
