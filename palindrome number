def is_palindrome(x):
    # Negative numbers are not palindromes
    if x < 0:
        return False
    num = x
    reversed_num = 0
    while num > 0:
        last_digit = num % 10
        reversed_num = (reversed_num * 10) + last_digit
        num //= 10
    return reversed_num == x
print(is_palindrome(12321))  # Returns: True
print(is_palindrome(-121)) # Returns: False
